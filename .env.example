# ═══════════════════════════════════════════════════════════
# AutoTest Framework · 环境变量配置模板
#
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env 中的敏感信息（密码、密钥等）
#   docker compose --env-file .env up -d
# ═══════════════════════════════════════════════════════════

# ── 部署环境 ──
# 可选值: dev | staging | production
ENV=dev

# ── PostgreSQL 主数据库 ──
POSTGRES_USER=autotest
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=autotest

# ── 数据库连接 URL（异步驱动） ──
# 格式: postgresql+asyncpg://user:password@host:port/database
# 容器内 host 固定为 postgres（服务名）
AUTOTEST_DB_URL=postgresql+asyncpg://autotest:change_me_in_production@postgres:5432/autotest

# ── Celery Broker (Redis) ──
# 容器内 host 固定为 redis（服务名）
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── API 安全 ──
# 生产环境必须设置强密钥
API_KEY=

# ── Worker 并发 ──
# Celery worker 并发数，建议 = CPU 核数 * 2
WORKER_CONCURRENCY=4

# ── Optional: Sentry / 错误追踪 ──
# SENTRY_DSN=

# ── Optional: 外部服务密钥 ──
# EXTERNAL_API_KEY=
